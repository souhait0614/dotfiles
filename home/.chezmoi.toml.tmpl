{{ $useSudo := false -}}
{{ $arch := .chezmoi.arch -}}

{{ if eq $arch "amd64" -}}
  {{ $arch = "x86_64" -}}
{{ end -}}
{{ $platform := printf "%s-%s" .chezmoi.os $arch -}}
{{ $brewCommand := "" -}}

{{ if eq $platform "darwin-arm64" -}}
  {{ $brewCommand = "/opt/homebrew/bin/brew" -}}
{{ end -}}

{{ if stdinIsATTY -}}
  {{ $useSudo = promptBoolOnce . "use_sudo" "Allow setup commands to use sudo" -}}
{{ else -}}
  {{ $useSudo = true -}}
{{ end -}}

[data]
  brew_command = {{ $brewCommand | quote }}
  platform = {{ $platform | quote }}
  useSudo = {{ $useSudo }}